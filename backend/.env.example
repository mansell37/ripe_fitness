# --- Database ---
# Local dev defaults to SQLite (no setup needed). On Railway, set DATABASE_URL
# to the managed Postgres connection string (Railway injects this automatically
# when you attach a Postgres plugin).
DATABASE_URL=sqlite:///./ripe_fitness.db

# --- App auth (single user) ---
# Password you type to log in; APP_API_TOKEN is the bearer token the frontend
# stores after login. Change both before deploying.
APP_PASSWORD=changeme
APP_API_TOKEN=dev-token-change-me

# --- Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Garmin Connect (unofficial garminconnect lib) ---
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Directory where OAuth tokens are cached so we don't log in every sync.
GARMIN_TOKEN_STORE=.garmin_tokens

# --- CORS ---
# Comma-separated origins allowed to call the API (your frontend URL).
CORS_ORIGINS=http://localhost:5173

# --- Auto-sync scheduler ---
# Pulls Garmin data at 08:00 / 14:00 / 20:00 in this timezone.
# Set to your local IANA timezone, e.g. Australia/Sydney, Europe/London.
AUTO_SYNC_ENABLED=true
SCHEDULER_TIMEZONE=Australia/Sydney
